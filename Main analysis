prepare_plot_data <- function(data) {
  data$k <- as.numeric(gsub("sugar_event_k", "", data$Variable))
  
  plot_data <- data[order(data$k), ]
  
  plot_data$signif <- ifelse(
    plot_data$P_Value < 0.001, "***",
    ifelse(
      plot_data$P_Value < 0.01, "**",
      ifelse(
        plot_data$P_Value < 0.05, "*",
        ifelse(
          plot_data$P_Value < 0.1, "+", ""
        )
      )
    )
  )
  
  return(plot_data)
}

