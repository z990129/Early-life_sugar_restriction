# Compare ---------------------------------
# Assessing the best fitted distribution using the Akaike and Bayesian Information Criterion.
library(dplyr)
library(survival)
library(survminer)
dat6$survey_yr_centered <- scale(dat6$survey_yr, center = TRUE, scale = FALSE)

dat6$Infections_yr <- dat6$followup_fo_birth_Diseases_of_Infections/365.25
dists <- list("exp", "weibull", "llogis", "lnorm", "gompertz")
get_model <- function(formula, dist, data) {
  tryCatch({
    model <- flexsurvreg(
      formula = formula,
      dist = dist,
      data = data
    )
    
    result <- c(
      model$res[, 1], 
      AIC = AIC(model),
      BIC = BIC(model),
      LogLik = model$loglik,
      Events = sum(model$data$Y[, 2]),  
      N = nrow(model$data$Y)  
    )
    return(result)
  }, error = function(e) {
    warning(paste("Failed to fit", dist, "distribution:", e$message))
    return(NA)
  })
}

surv_formula <- Surv(Infections_yr, outcome_fo_birth_Diseases_of_Infections) ~ 
  sugar_ex_gro + sex + ethnic + birth_place + only_fm_diabetes_v0 + only_fm_cvd_v0 +
  north_decile + east_decile + birth_month + survey_yr_centered

models <- lapply(dists, function(dist) {
  get_model(formula = surv_formula, dist = dist, data = dat6)
})
names(models) <- dists
results_summary <- data.frame(
  Distribution = character(),
  AIC = numeric(),
  BIC = numeric(),
  LogLik = numeric(),
  Events = numeric(),
  N = numeric(),
  stringsAsFactors = FALSE
)

for (i in seq_along(models)) {
  if (!is.na(models[[i]][1])) { 
    results_summary <- rbind(results_summary, data.frame(
      Distribution = names(models)[i],
      AIC = models[[i]]["AIC"],
      BIC = models[[i]]["BIC"],
      LogLik = models[[i]]["LogLik"],
      Events = models[[i]]["Events"],
      N = models[[i]]["N"],
      stringsAsFactors = FALSE
    ))
  }
}

results_summary$AIC_formatted <- sprintf("%.2f", results_summary$AIC)
results_summary$BIC_formatted <- sprintf("%.2f", results_summary$BIC)


